# Lightspeed Retail R-Series API Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Setup steps:
# 1. Set CLIENT_ID and CLIENT_SECRET below (from your Lightspeed app registration)
# 2. Get the authorization URL:
#      python3 scripts/lightspeed_auth.py auth-url
# 3. Visit that URL in your browser, authorize your app
# 4. Copy the ?code=XXXXX from the redirect URL
# 5. Exchange the code for tokens:
#      python3 scripts/lightspeed_auth.py exchange XXXXX
# 6. Copy the Account ID and Refresh Token into this file
#
# OAuth endpoints:
#   Auth:  https://cloud.lightspeedapp.com/oauth/authorize.php
#   Token: https://cloud.merchantos.com/oauth/access_token.php
#   API:   https://api.lightspeedapp.com/API/Account/{ID}/

LIGHTSPEED_ACCOUNT_ID=your_account_id_here
LIGHTSPEED_CLIENT_ID=your_client_id_here
LIGHTSPEED_CLIENT_SECRET=your_client_secret_here
LIGHTSPEED_REFRESH_TOKEN=your_refresh_token_here
