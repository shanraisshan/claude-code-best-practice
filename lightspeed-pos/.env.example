# Lightspeed Retail R-Series API Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# To get these values:
# 1. Go to https://cloud.merchantos.com/oauth/register.php to register your app
# 2. Complete the OAuth flow to get your refresh token
# 3. Your Account ID is visible in your Lightspeed admin URL

LIGHTSPEED_ACCOUNT_ID=your_account_id_here
LIGHTSPEED_CLIENT_ID=your_client_id_here
LIGHTSPEED_CLIENT_SECRET=your_client_secret_here
LIGHTSPEED_REFRESH_TOKEN=your_refresh_token_here
